# Serveur
PORT=3000

#BDD PostgreSQL
DATABASE_URL="postgresql://cinesdelices:cinesdelices@localhost:5432/cinesdelices"

# JWT — générer une clé solide avec :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN="7d"

# TMDB
TMDB_API_KEY=TMDB_API_KEY
TMDB_BASE_URL="https://api.themoviedb.org/3"

# URL du front-end (pour CORS)
# En développement local :
CLIENT_URL="http://localhost:5173"
# Avec ngrok (déploiement) — remplacer par l'URL ngrok du front :
# CLIENT_URL="https://xxxx-xxxx.ngrok-free.app"

# URL publique du back (pour Swagger et les tests)
# En développement local :
API_BASE_URL="http://localhost:3000"
# Avec ngrok — remplacer par l'URL ngrok du back :
# API_BASE_URL="https://yyyy-yyyy.ngrok-free.app"
