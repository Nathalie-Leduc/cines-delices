# serveur
PORT=3000

#BDD PostgreSQL
DATABASE_URL="postgresql://cinedelices:cinedelices@localhost:5432/cinedelices"

# JWT — générer une clé solide avec :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN="7d"


TMDB_API_KEY=TMDB_API_KEY
TMDB_BASEURL="https://apit.themoviedb.org/3"

# URL du front-end (pour CORS)
# En développement local :
CLIENT_URL="http://localhost:5173"
# Avec ngrok (déploiement) — remplacer par l'URL ngrok du front :
# CLIENT_URL="https://xxxx-xxxx.ngrok-free.app"

# URL publique du back (pour Swagger et les tests)
# En développement local :
API_BASE_URL="http://localhost:3000"
# Avec ngrok — remplacer par l'URL ngrok du back :
# API_BASE_URL="https://yyyy-yyyy.ngrok-free.app"

# URLs API front-end
VITE_INGREDIENT_SEARCH_API_URL=http://localhost:3001/api/ingredients/search
VITE_RECIPE_API_URL=http://localhost:3001/api/recipes
VITE_USER_API_URL=http://localhost:3001/api/users
