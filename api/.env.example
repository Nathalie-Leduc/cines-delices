# serveur
PORT=3000

#BDD PostgreSQL
DATABASE_URL="postgresql://cinesdelices:cinesdelices@localhost:5432/cinesdelices"

# JWT — générer une clé solide avec :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN="7h"

# TMDB
TMDB_API_KEY=TMDB_API_KEY
TMDB_BASE_URL="https://api.themoviedb.org/3"

# URL du front-end (pour CORS)
# En développement local :
CLIENT_URL="http://localhost:5173"
# Avec ngrok (déploiement) — remplacer par l'URL ngrok du front :
# CLIENT_URL="https://xxxx-xxxx.ngrok-free.app"

# URL publique du back (pour Swagger et les tests)
# En développement local :
API_BASE_URL="http://localhost:3000"
# Avec ngrok — remplacer par l'URL ngrok du back :
API_BASE_URL="https://mirta-unfragile-curvedly.ngrok-free.dev"

# ============================================================
# CONFIGURATION EMAIL (SMTP) — à ajouter dans votre .env
# ============================================================

# ── OPTION 1 : Mailtrap (DÉVELOPPEMENT) ──
# Gratuit, capture les emails sans les envoyer réellement.
# Créez un compte sur https://mailtrap.io (gratuit)
# → Allez dans Email Testing → My Inbox → SMTP Settings
# → Copiez les identifiants ci-dessous

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=votre_username_mailtrap
SMTP_PASS=votre_password_mailtrap
SMTP_FROM="Ciné Délices <noreply@cine-delices.fr>"

# ── OPTION 2 : Brevo / Sendinblue (PRODUCTION) ──
# Gratuit jusqu'à 300 emails/jour.
# Créez un compte sur https://www.brevo.com (gratuit)
# → Allez dans Settings → SMTP & API → SMTP
# → Activez le SMTP et copiez les identifiants

# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=votre_email@example.com
# SMTP_PASS=votre_cle_smtp_brevo
# SMTP_FROM="Ciné Délices <noreply@cine-delices.fr>"

# ── OPTION 3 : Gmail (SIMPLE MAIS LIMITÉ) ──
# Nécessite un "mot de passe d'application" Google.
# https://myaccount.google.com/apppasswords

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASS=votre-mot-de-passe-application
# SMTP_FROM="Ciné Délices <votre-email@gmail.com>"
