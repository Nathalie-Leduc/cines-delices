generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  ADMIN
}

enum RecipeStatus {
  DRAFT
  PENDING
  PUBLISHED
}

enum MediaType {
  MOVIE
  SERIES
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  pseudo       String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now()) @map("created_at")
  recipes      Recipe[]

  @@index([email])
  @@map("users")
}

model Category {
  id          String  @id @default(uuid())
  nom         String  @unique
  description String?
  recipes     Recipe[]

  @@map("categories")
}

model Genre {
  id          String       @id @default(uuid())
  nom         String
  tmdbGenreId Int          @unique @map("tmdb_genre_id")
  media       MediaGenre[]

  @@map("genres")
}

model MediaGenre {
  mediaId String @map("media_id")
  genreId String @map("genre_id")
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([mediaId, genreId])
  @@map("media_genres")
}

model Media {
  id        String      @id @default(uuid())
  tmdbId    Int         @unique @map("tmdb_id")
  titre     String
  type      MediaType
  posterUrl String?     @map("poster_url")
  synopsis  String?
  annee     Int?
  createdAt DateTime    @default(now()) @map("created_at")
  genres    MediaGenre[]
  recipes   Recipe[]

  @@index([tmdbId])
  @@index([type])
  @@map("media")
}

model Recipe {
  id               String             @id @default(uuid())
  titre            String
  instructions     String
  nombrePersonnes  Int?               @map("nombre_personnes")
  tempsPreparation Int?               @map("temps_preparation")
  tempsCuisson     Int?               @map("temps_cuisson")
  status           RecipeStatus       @default(DRAFT)
  rejectionReason  String?            @map("rejection_reason")
  userId           String             @map("user_id")
  categoryId       String             @map("category_id")
  mediaId          String             @map("media_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  media            Media              @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  ingredients      RecipeIngredient[]

  @@index([status])
  @@index([userId])
  @@index([categoryId])
  @@index([mediaId])
  @@map("recipes")
}

model RecipeIngredient {
  recipeId     String     @map("recipe_id")
  ingredientId String     @map("ingredient_id")
  quantity     String?
  unit         String?
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@id([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model Ingredient {
  id      String             @id @default(uuid())
  nom     String             @unique
  recipes RecipeIngredient[]

  @@index([nom])
  @@map("ingredients")
}
