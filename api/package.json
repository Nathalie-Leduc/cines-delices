{
  "name": "cines-delices-api",
  "version": "1.0.0",
  "description": "CinéDélices — API",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "lint": "eslint .",
    "test:run": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset":   "prisma migrate reset --force && node prisma/seed.js",
    "test":       "node tests/test-api.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.13.1",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prisma": "^7.5.0",
    "vitest": "^4.1.0",
    "nodemon": "^3.1.7"
  },
   "prisma": {
    "seed": "node prisma/seed.js"
  }
}
