{
  "name": "cines-delices-api",
  "version": "1.0.0",
  "description": "CinéDélices — API",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "lint": "eslint .",
    "convert:images": "node scripts/convert-images-to-webp.mjs",
    "convert:posters": "node scripts/migrate-posters-to-webp.mjs",
    "convert:all": "node scripts/convert-images-to-webp.mjs && node scripts/migrate-posters-to-webp.mjs",
    "fix:media": "node scripts/fix-media-details.mjs",
    "swagger:validate": "node src/docs/validateSwaggerSpec.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && node prisma/seed-v4.js",
    "test": "API_BASE_URL=https://cines-delices-production.up.railway.app node tests/test-api.js",
    "test:security": "API_BASE_URL=https://cines-delices-production.up.railway.app node tests/test-api-security.js",
    "test:all": "API_BASE_URL=https://cines-delices-production.up.railway.app node tests/test-api.js && API_BASE_URL=https://cines-delices-production.up.railway.app node tests/test-api-security.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "nodemon": "^3.1.7",
    "prisma": "^7.6.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "packageManager": "pnpm@10.33.0"
}
